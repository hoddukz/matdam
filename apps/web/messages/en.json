  "privacyPolicy": {
    "title": "Privacy Policy",
    "effectiveDate": "Effective Date: February 23, 2026",
    "introTitle": "Introduction",
    "introContent": "MatDam (\"we\", \"us\", \"our\") operates the MatDam web application. This Privacy Policy explains how we collect, use, and protect your personal information when you use our service.",
    "collectTitle": "Information We Collect",
    "collectContent": "When you sign in with Google, we collect your email address and display name. You may also provide a custom display name during onboarding. When you use the service, we collect the recipes and content you create.",
    "useTitle": "How We Use Your Information",
    "useContent": "We use your information to: authenticate your account, provide and improve the service, display your recipes and profile to other users, and send important service-related notifications.",
    "thirdPartyTitle": "Third-Party Services",
    "thirdPartyContent": "We use the following third-party services: Supabase (authentication and database), Vercel (hosting), and PostHog (anonymous usage analytics). These services may process your data according to their own privacy policies.",
    "retentionTitle": "Data Retention and Deletion",
    "retentionContent": "We retain your data for as long as your account is active. You may request deletion of your account and associated data by contacting us. Upon deletion, your personal data will be removed within 30 days.",
    "contactTitle": "Contact",
    "contactContent": "If you have questions about this Privacy Policy, please contact us at: matdam.app@gmail.com"
  },
  "termsOfService": {
    "title": "Terms of Service",
    "effectiveDate": "Effective Date: February 23, 2026",
    "acceptanceTitle": "Acceptance of Terms",
    "acceptanceContent": "By accessing or using MatDam, you agree to be bound by these Terms of Service. If you do not agree, please do not use the service.",
    "serviceTitle": "Service Description",
    "serviceContent": "MatDam is a platform for discovering, creating, remixing, and sharing Korean recipes. Users can create original recipes, remix existing recipes, and browse content created by other users.",
    "accountTitle": "User Accounts",
    "accountContent": "You must sign in with a valid Google account to create, remix, or bookmark recipes. You are responsible for all activity under your account.",
    "contentTitle": "User Content and Recipes",
    "contentContent": "You retain ownership of original recipes you create. By publishing a recipe on MatDam, you grant other users the right to view and remix your recipe with proper attribution. Remixed recipes must credit the original author.",
    "conductTitle": "Prohibited Conduct",
    "conductContent": "You agree not to: post offensive, harmful, or misleading content; impersonate others; attempt to disrupt or exploit the service; or violate any applicable laws.",
    "disclaimerTitle": "Disclaimer",
    "disclaimerContent": "MatDam is provided \"as is\" without warranties of any kind. We do not guarantee the accuracy or safety of user-submitted recipes. Always use your own judgment when following recipes, especially regarding food allergies and safety.",
    "changesTitle": "Changes to Terms",
    "changesContent": "We may update these terms at any time. Continued use of the service after changes constitutes acceptance of the new terms.",
